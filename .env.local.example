# 复制为 .env.local 后填入真实值（.env.local 已 gitignore，不会提交）
# 用途：
#   1) node .tmp-local-dev-server.mjs  — 读取 process.env 做 AI 生成
#   2) source .env.local 后再 func start — 可选，与 api/local.settings.json 二选一

AOAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AOAI_DEPLOYMENT=YOUR-DEPLOYMENT-NAME
AOAI_API_KEY=YOUR-AOAI-KEY
AOAI_API_VERSION=2024-12-01-preview

# 可选：限流（默认 15/小时/IP，300/天全局）
# RL_PER_IP_HOUR=15
# RL_GLOBAL_DAY=300
